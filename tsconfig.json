{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@test": ["src/test/index.ts"]
    },

    "outDir": "./bin"
  },
  "include": [
    "src/**/*.ts"
  ]
}